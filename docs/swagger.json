{
    "swagger": "2.0",
    "info": {
        "description": "IoT Scale Inventory Management — FDA 21 CFR Part 11 compliant REST API.",
        "title": "Inventory Management System API",
        "termsOfService": "https://github.com/inventory-manage",
        "contact": {
            "name": "Inventory Manage Team",
            "email": "dev@inventory-manage.local"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/v1/calibrations": {
            "post": {
                "description": "Creates a new calibration profile for an IoT scale",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "calibration"
                ],
                "summary": "Register calibration config for a device",
                "parameters": [
                    {
                        "description": "Calibration config payload",
                        "name": "config",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_internal_model.CalibrationConfig"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ErrorResponseData"
                        }
                    }
                }
            }
        },
        "/api/v1/calibrations/{device_id}/active": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "calibration"
                ],
                "summary": "Get the active calibration config for a device",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Device ID",
                        "name": "device_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ResponseData"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ErrorResponseData"
                        }
                    }
                }
            }
        },
        "/api/v1/calibrations/{device_id}/history": {
            "get": {
                "description": "Retrieve old configurations and triggers mapped against this device ID.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "calibration"
                ],
                "summary": "Get calibration history (append-only)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Device ID",
                        "name": "device_id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "default": 0,
                        "description": "Pagination Offset",
                        "name": "offset",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 20,
                        "description": "Pagination Limit",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ResponseData"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ErrorResponseData"
                        }
                    }
                }
            }
        },
        "/api/v1/calibrations/{device_id}/update": {
            "post": {
                "description": "Deactivates the current config and creates a new one in a single transaction (initial, periodic, drift_correction)",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "calibration"
                ],
                "summary": "Update / Add a new active calibration config for a device",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Device ID",
                        "name": "device_id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Calibration update payload",
                        "name": "config",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_internal_model.UpdateCalibrationParams"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ResponseData"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ErrorResponseData"
                        }
                    }
                }
            }
        },
        "/api/v1/devices": {
            "get": {
                "description": "Returns all registered devices, optionally filtered by status or sku_code",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "devices"
                ],
                "summary": "List all devices",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Device status filter (active|inactive|maintenance)",
                        "name": "status",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "SKU code filter",
                        "name": "sku_code",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ResponseData"
                        }
                    }
                }
            },
            "post": {
                "description": "Creates a new device record in the inventory system",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "devices"
                ],
                "summary": "Register a new IoT scale device",
                "parameters": [
                    {
                        "description": "Device payload",
                        "name": "device",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_internal_model.Device"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ErrorResponseData"
                        }
                    }
                }
            }
        },
        "/api/v1/devices/{id}": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "devices"
                ],
                "summary": "Get a device by ID",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Device ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ResponseData"
                        }
                    }
                }
            },
            "put": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "devices"
                ],
                "summary": "Update a device",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Device ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Updated device data",
                        "name": "device",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_internal_model.Device"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ResponseData"
                        }
                    }
                }
            },
            "delete": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "devices"
                ],
                "summary": "Delete a device",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Device ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ResponseData"
                        }
                    }
                }
            }
        },
        "/api/v1/inventory/current": {
            "get": {
                "description": "Returns the latest inventory snapshots across all connected devices",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "inventory"
                ],
                "summary": "Get current inventory snapshots across all SKUs",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ResponseData"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ErrorResponseData"
                        }
                    }
                }
            }
        },
        "/api/v1/inventory/{sku_code}/current": {
            "get": {
                "description": "Returns the latest inventory snapshots for devices holding the specific SKU",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "inventory"
                ],
                "summary": "Get current inventory for a specific SKU",
                "parameters": [
                    {
                        "type": "string",
                        "description": "SKU Code",
                        "name": "sku_code",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ResponseData"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/inventory-manage_pkg_response.ErrorResponseData"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "inventory-manage_internal_model.CalibrationConfig": {
            "type": "object",
            "properties": {
                "calibration_type": {
                    "type": "string"
                },
                "capacity_max": {
                    "type": "number"
                },
                "created_at": {
                    "type": "string"
                },
                "created_by": {
                    "type": "string"
                },
                "deactivated_at": {
                    "type": "string"
                },
                "device_id": {
                    "type": "string"
                },
                "effective_from": {
                    "type": "string"
                },
                "hardware_config": {
                    "type": "object",
                    "additionalProperties": true
                },
                "id": {
                    "type": "integer"
                },
                "span_value": {
                    "type": "number"
                },
                "unit": {
                    "type": "string"
                },
                "zero_value": {
                    "type": "number"
                }
            }
        },
        "inventory-manage_internal_model.Device": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "device_id": {
                    "type": "string"
                },
                "location": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "sku_code": {
                    "type": "string"
                },
                "status": {
                    "$ref": "#/definitions/inventory-manage_internal_model.DeviceStatus"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "inventory-manage_internal_model.DeviceStatus": {
            "type": "string",
            "enum": [
                "active",
                "inactive",
                "maintenance"
            ],
            "x-enum-varnames": [
                "StatusActive",
                "StatusInactive",
                "StatusMaintenance"
            ]
        },
        "inventory-manage_internal_model.UpdateCalibrationParams": {
            "type": "object",
            "required": [
                "calibration_type",
                "capacity_max",
                "created_by",
                "span_value",
                "unit",
                "zero_value"
            ],
            "properties": {
                "calibration_type": {
                    "type": "string"
                },
                "capacity_max": {
                    "type": "number"
                },
                "created_by": {
                    "type": "string"
                },
                "hardware_config": {
                    "type": "object",
                    "additionalProperties": true
                },
                "span_value": {
                    "type": "number"
                },
                "unit": {
                    "type": "string"
                },
                "zero_value": {
                    "type": "number"
                }
            }
        },
        "inventory-manage_pkg_response.ErrorResponseData": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "detail": {
                    "description": "optional extra context",
                    "type": "string"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "inventory-manage_pkg_response.ResponseData": {
            "type": "object",
            "properties": {
                "code": {
                    "description": "business status code (20001, 40001 …)",
                    "type": "integer"
                },
                "data": {
                    "description": "response payload (nil on error)"
                },
                "message": {
                    "description": "human-readable message",
                    "type": "string"
                }
            }
        }
    }
}